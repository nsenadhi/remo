OPENAI_KEY=your_openai_key
S3_KEY_ID=your_s3_key_id
S3_SECRET_KEY=your_s3_secret_key
S3_BUCKET_NAME=your_bucket_name
AWS_REGION=your_aws_region
FLASK_ENV=development
DEBUG=True
EDGE_DEVICE_URL=https://your-edge-device-host:5000
EDGE_API_KEY=your_edge_api_key
MQTT_BROKER_HOST=your_mqtt_host
MQTT_BROKER_PORT=8883
MQTT_USE_TLS=true
MQTT_CERT_PATH=path/to/certificate.pem.crt
MQTT_KEY_PATH=path/to/private.pem.key
MQTT_CA_PATH=path/to/AmazonRootCA1.pem
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_FORWARD_CHAT=true
NGROK_AUTHTOKEN=your_ngrok_authtoken
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=your_email@example.com
SMTP_USE_TLS=true
